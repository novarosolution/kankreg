{
  "expo": {
    "name": "KankreG",
    "slug": "kankreg",
    "scheme": "kankreg",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "userInterfaceStyle": "automatic",
    "icon": "./assets/app-icon-light.png",
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow KankreG to access your location to auto-fill delivery address.",
        "NSUserNotificationUsageDescription": "Allow KankreG to send order updates and important announcements."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon-light.png",
        "backgroundColor": "#F5EFE4"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow KankreG to use your location to auto-fill delivery address."
        }
      ],
      "expo-notifications",
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-video"
    ]
  }
}
