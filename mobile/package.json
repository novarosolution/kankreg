{
  "name": "kankreg-ecommerce-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-chart-kit"
        ]
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "reset:cache": "rm -rf node_modules/.cache .expo && (watchman watch-del-all 2>/dev/null || true)",
    "android": "JAVA_HOME=\"${JAVA_HOME:-/Applications/Android Studio.app/Contents/jbr/Contents/Home}\" expo run:android",
    "android:clean": "npm run reset:cache && expo start --android --clear",
    "ios": "expo run:ios",
    "ios:dev": "expo run:ios --device",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "ios:clean": "npm run reset:cache && expo start --ios --clear",
    "ios:reset-expo-go": "xcrun simctl uninstall booted host.exp.Exponent 2>/dev/null || true",
    "web": "expo start --web",
    "web:export": "expo export --platform web",
    "export:web": "npm run optimize:web && npm run web:export && node scripts/post-export-web.js",
    "optimize:web": "node scripts/optimize-marketing-web.js",
    "icons:generate": "node scripts/generate-app-icons.js",
    "icons:app": "node scripts/generate-app-icons.js",
    "brand:generate": "node scripts/generate-brand-assets.js",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/hanken-grotesk": "^0.4.3",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/metro-runtime": "~5.0.5",
    "@expo/vector-icons": "^14.1.0",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@howincodes/expo-dynamic-app-icon": "^3.0.2",
    "@mapbox/polyline": "^1.2.1",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/native-stack": "^7.3.21",
    "expo": "~53.0.0",
    "expo-apple-authentication": "~7.2.4",
    "expo-asset": "~11.1.7",
    "expo-auth-session": "~6.2.1",
    "expo-blur": "~14.1.5",
    "expo-build-properties": "~0.14.8",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-notifications": "~0.31.5",
    "expo-print": "~14.1.4",
    "expo-sharing": "~13.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-video": "~2.2.2",
    "expo-web-browser": "~14.2.0",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-leaflet": "^5.0.0",
    "react-native": "0.79.6",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-web": "^0.20.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-expo": "~9.2.0",
    "sharp": "^0.33.5"
  }
}
