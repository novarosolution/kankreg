# Copy to .env and adjust. Expo loads EXPO_PUBLIC_* at build time.
# Backend default port is 5001 (see backend/.env.example).
# Base URL may include /api if you proxy that way — the server serves both /products and /api/products.

# Local development:
# EXPO_PUBLIC_API_URL=http://127.0.0.1:5001

# Render production (live API):
EXPO_PUBLIC_API_URL=https://kankregserver.onrender.com
# EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=....apps.googleusercontent.com
