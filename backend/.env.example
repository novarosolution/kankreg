PORT=5001
# Optional comma-separated web origins (Vercel preview, staging)
# CORS_EXTRA_ORIGINS=https://kankreg.vercel.app
# Use the exact database name casing from Atlas (e.g. Zeevan not zeevan)
MONGO_URI=mongodb://127.0.0.1:27017/kankreg_ecommerce
# Optional override if the path segment in MONGO_URI has wrong case:
# MONGO_DB_NAME=Zeevan
JWT_SECRET=replace_with_a_long_secret
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
# Razorpay (server-only secrets — never ship to client)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=replace_with_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_webhook_secret

# Google Maps Platform — Directions API (server-only). Enables road-following route on live tracking map.
# Create a key with Directions API enabled; restrict by IP on production.
# GOOGLE_MAPS_ROUTES_API_KEY=your_server_key

# OAuth (comma-separated Google client IDs: web, iOS, Android)
# GOOGLE_OAUTH_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
# APPLE_CLIENT_ID=com.yourapp.service
# APPLE_BUNDLE_ID=com.yourapp.bundle
